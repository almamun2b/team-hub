{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile --prod=false && pnpm --filter @team-hub/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @team-hub/web start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "environment": {
      "NODE_ENV": "production",
      "NODE_VERSION": "20"
    }
  }
}