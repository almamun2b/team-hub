model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  changes     Json?
  userId      String
  workspaceId String
  
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
